    {
      "type": "vis",
      "id": "top-customers-table",
      "grid": {
        "x": 0,
        "y": 23,
        "w": 24,
        "h": 12
      },
      "config": {
        "title": "Top Customers by Spend",
        "type": "data_table",
        "data_source": {
          "type": "data_view_spec",
          "index_pattern": "kibana_sample_data_ecommerce",
          "time_field": "order_date"
        },
        "metrics": [
          {
            "operation": "sum",
            "field": "taxful_total_price"
          },
          {
            "operation": "count"
          },
          {
            "operation": "average",
            "field": "taxful_total_price"
          }
        ],
        "rows": [
          {
            "operation": "terms",
            "fields": ["customer_full_name.keyword"],
            "limit": 10,
            "rank_by": {
              "type": "metric",
              "metric_index": 0,
              "direction": "desc"
            }
          }
        ]
      }
    },
    {
      "type": "vis",
      "id": "top-countries-table",
      "grid": {
        "x": 24,
        "y": 23,
        "w": 24,
        "h": 12
      },
      "config": {
        "title": "Top Countries by Revenue",
        "type": "data_table",
        "data_source": {
          "type": "data_view_spec",
          "index_pattern": "kibana_sample_data_ecommerce",
          "time_field": "order_date"
        },
        "metrics": [
          {
            "operation": "sum",
            "field": "taxful_total_price"
          },
          {
            "operation": "count"
          },
          {
            "operation": "unique_count",
            "field": "customer_id"
          },
          {
            "operation": "average",
            "field": "taxful_total_price"
          }
        ],
        "rows": [
          {
            "operation": "terms",
            "fields": ["geoip.country_iso_code"],
            "limit": 10,
            "rank_by": {
              "type": "metric",
              "metric_index": 0,
              "direction": "desc"
            }
          }
        ]
      }
    },
