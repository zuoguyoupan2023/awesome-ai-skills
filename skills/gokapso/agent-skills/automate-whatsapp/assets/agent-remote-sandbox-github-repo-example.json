      "flow_agent_resources": [
        {
          "resource_type": "github_repository",
          "repo_url": "https://github.com/acme/acme-app",
          "branch": "main",
          "pat": "github_pat_replace_me"
        }
      ],
      "flow_agent_webhooks": [],
      "flow_agent_function_tools": [],
      "flow_agent_mcp_servers": []
    }
  }
}
