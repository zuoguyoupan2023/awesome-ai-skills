    {
      "type": "text",
      "id": "rt32",
      "x": 1630,
      "y": 1315,
      "width": 420,
      "height": 105,
      "text": "CARDIAC CYCLE (0.8 sec total)\n• Atrial systole: 0.1 sec\n• Ventricular systole: 0.3 sec\n• Ventricular diastole: 0.4 sec\nHeart Sounds:\n  LUBB (AV valves close)\n  DUPP (Semilunar valves close)",
      "originalText": "CARDIAC CYCLE (0.8 sec total)\n• Atrial systole: 0.1 sec\n• Ventricular systole: 0.3 sec\n• Ventricular diastole: 0.4 sec\nHeart Sounds:\n  LUBB (AV valves close)\n  DUPP (Semilunar valves close)",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "center",
      "verticalAlign": "middle",
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
