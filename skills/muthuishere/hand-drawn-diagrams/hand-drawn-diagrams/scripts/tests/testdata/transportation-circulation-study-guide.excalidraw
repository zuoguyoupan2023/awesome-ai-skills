    {
      "type": "text",
      "id": "rt33",
      "x": 2090,
      "y": 1315,
      "width": 420,
      "height": 105,
      "text": "HEARTBEAT CONDUCTION\n• SA node (pacemaker) in RA\n  → AV node\n  → Bundle of His\n  → Purkinje fibres\nPulse: 72-75 beats/min\nBP: 120/80 mmHg (systolic/diastolic)",
      "originalText": "HEARTBEAT CONDUCTION\n• SA node (pacemaker) in RA\n  → AV node\n  → Bundle of His\n  → Purkinje fibres\nPulse: 72-75 beats/min\nBP: 120/80 mmHg (systolic/diastolic)",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "center",
      "verticalAlign": "middle",
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
